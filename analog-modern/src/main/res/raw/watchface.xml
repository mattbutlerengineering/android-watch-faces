<WatchFace width="450" height="450">
    <Scene>
        <!-- Background with Radial Gradient -->
        <PartDraw x="0" y="0" width="450" height="450" contentDescription="Modern background">
            <Rectangle x="0" y="0" width="450" height="450">
                <Fill>
                    <RadialGradient
                        centerX="225" centerY="225"
                        radius="225"
                        colors="#FF1A1A2E #FF000000"
                        positions="0.0 1.0">
                        <Variant mode="AMBIENT" target="colors" value="#FF000000 #FF000000" />
                    </RadialGradient>
                </Fill>
            </Rectangle>
        </PartDraw>

        <!-- Hour Markers -->
        <Group x="0" y="0" width="450" height="450">
            <!-- 12, 3, 6, 9 -->
            <PartDraw x="223" y="20" width="4" height="25" contentDescription="Marker 12">
                <Rectangle x="0" y="0" width="4" height="25"><Fill color="#FFFFFFFF" /></Rectangle>
            </PartDraw>
            <PartDraw x="405" y="223" width="25" height="4" contentDescription="Marker 3">
                <Rectangle x="0" y="0" width="25" height="4"><Fill color="#FFFFFFFF" /></Rectangle>
            </PartDraw>
            <PartDraw x="223" y="405" width="4" height="25" contentDescription="Marker 6">
                <Rectangle x="0" y="0" width="4" height="25"><Fill color="#FFFFFFFF" /></Rectangle>
            </PartDraw>
            <PartDraw x="20" y="223" width="25" height="4" contentDescription="Marker 9">
                <Rectangle x="0" y="0" width="25" height="4"><Fill color="#FFFFFFFF" /></Rectangle>
            </PartDraw>
        </Group>

        <!-- Complications at 3 and 9 -->
        <!-- Battery at 9 -->
        <ComplicationSlot slotId="0" supportedTypes="SHORT_TEXT" x="70" y="200" width="50" height="50">
            <BoundingOval x="0" y="0" width="50" height="50" />
            <DefaultProviderPolicy defaultSystemProvider="WATCH_BATTERY" defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="50" height="50" contentDescription="Battery">
                    <Text align="CENTER" y="25">
                        <Template>%s</Template>
                        <Parameter expression="[COMPLICATION.TEXT]" />
                        <Font family="SYNC_TO_DEVICE" size="14" color="#FFAAAAAA" />
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Heart Rate at 3 -->
        <ComplicationSlot slotId="1" supportedTypes="SHORT_TEXT" x="330" y="200" width="50" height="50">
            <BoundingOval x="0" y="0" width="50" height="50" />
            <DefaultProviderPolicy defaultSystemProvider="HEART_RATE" defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="50" height="50" contentDescription="Heart rate">
                    <Text align="CENTER" y="25">
                        <Template>%s</Template>
                        <Parameter expression="[COMPLICATION.TEXT]" />
                        <Font family="SYNC_TO_DEVICE" size="14" color="#FFAAAAAA" />
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Analog Clock -->
        <AnalogClock x="0" y="0" width="450" height="450">
            <!-- Hour Hand -->
            <HourHand x="219" y="110" width="12" height="115" pivotX="6" pivotY="115" contentDescription="Hour hand">
                <PartDraw x="0" y="0" width="12" height="115">
                    <Rectangle x="0" y="0" width="12" height="115">
                        <Fill color="#FFFFFFFF">
                            <Variant mode="AMBIENT" target="alpha" value="0" />
                        </Fill>
                        <Stroke color="#FFFFFFFF" thickness="2">
                             <Variant mode="AMBIENT" target="alpha" value="200" />
                        </Stroke>
                    </Rectangle>
                </PartDraw>
            </HourHand>

            <!-- Minute Hand -->
            <MinuteHand x="221" y="60" width="8" height="165" pivotX="4" pivotY="165" contentDescription="Minute hand">
                <PartDraw x="0" y="0" width="8" height="165">
                    <Rectangle x="0" y="0" width="8" height="165">
                        <Fill color="#FFFFFFFF">
                            <Variant mode="AMBIENT" target="alpha" value="0" />
                        </Fill>
                        <Stroke color="#FFFFFFFF" thickness="2">
                             <Variant mode="AMBIENT" target="alpha" value="200" />
                        </Stroke>
                    </Rectangle>
                </PartDraw>
            </MinuteHand>

            <!-- Second Hand (Smooth) -->
            <SecondHand x="224" y="40" width="2" height="210" pivotX="1" pivotY="185" contentDescription="Second hand">
                <PartDraw x="0" y="0" width="2" height="210">
                    <Rectangle x="0" y="0" width="2" height="210">
                        <Fill color="#FFFF0000" />
                    </Rectangle>
                </PartDraw>
                <Sweep frequency="15" />
                <Variant mode="AMBIENT" target="alpha" value="0" />
            </SecondHand>
        </AnalogClock>

        <!-- Center Hub -->
        <PartDraw x="220" y="220" width="10" height="10" contentDescription="Center hub">
            <Ellipse x="0" y="0" width="10" height="10">
                <Fill color="#FFFFFFFF" />
            </Ellipse>
        </PartDraw>
    </Scene>
</WatchFace>
