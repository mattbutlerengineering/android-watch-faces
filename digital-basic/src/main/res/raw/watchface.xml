<WatchFace width="450" height="450">
    <UserConfigurations>
        <ColorConfiguration id="themeColor" displayName="@string/theme_color" defaultValue="0">
            <ColorOption id="0" displayName="@string/theme_green" colors="#FF00FF00" />
            <ColorOption id="1" displayName="@string/theme_blue" colors="#FF00FFFF" />
            <ColorOption id="2" displayName="@string/theme_red" colors="#FFFF0000" />
            <ColorOption id="3" displayName="@string/theme_gold" colors="#FFFFD700" />
        </ColorConfiguration>
    </UserConfigurations>
    <Scene>
        <!-- Background -->
        <PartDraw x="0" y="0" width="450" height="450" contentDescription="Background">
            <Rectangle x="0" y="0" width="450" height="450">
                <Fill color="#FF000000" />
            </Rectangle>
        </PartDraw>

        <!-- Battery Complication -->
        <ComplicationSlot slotId="0"
                          supportedTypes="SHORT_TEXT"
                          x="175" y="70" width="100" height="50">
            <BoundingRect x="0" y="0" width="100" height="50" />
            <DefaultProviderPolicy
                defaultSystemProvider="WATCH_BATTERY"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="100" height="50" contentDescription="Battery level">
                    <Text align="CENTER" y="25">
                        <Template>%s</Template>
                        <Parameter expression="[COMPLICATION.TEXT]" />
                        <Font family="SYNC_TO_DEVICE" size="24" color="[CONFIGURATION.themeColor.0]">
                            <Variant mode="AMBIENT" target="color" value="#FF888888" />
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Heart Rate Complication -->
        <ComplicationSlot slotId="1"
                          supportedTypes="SHORT_TEXT"
                          x="175" y="360" width="100" height="50">
            <BoundingRect x="0" y="0" width="100" height="50" />
            <DefaultProviderPolicy
                defaultSystemProvider="HEART_RATE"
                defaultSystemProviderType="SHORT_TEXT" />
            <Complication type="SHORT_TEXT">
                <PartText x="0" y="0" width="100" height="50" contentDescription="Heart rate">
                    <Text align="CENTER" y="25">
                        <Template>%s</Template>
                        <Parameter expression="[COMPLICATION.TEXT]" />
                        <Font family="SYNC_TO_DEVICE" size="24" color="[CONFIGURATION.themeColor.0]">
                            <Variant mode="AMBIENT" target="color" value="#FF888888" />
                        </Font>
                    </Text>
                </PartText>
            </Complication>
        </ComplicationSlot>

        <!-- Digital Clock -->
        <Group x="0" y="150" width="450" height="150">
            <DigitalClock>
                <!-- Time HH:mm -->
                <TimeText format="HH:mm" align="CENTER" x="225" y="60">
                    <Font family="SYNC_TO_DEVICE" size="100" color="#FFFFFFFF" />
                </TimeText>
                <!-- Seconds -->
                <TimeText format=":ss" align="LEFT" x="350" y="60">
                    <Font family="SYNC_TO_DEVICE" size="40" color="#FFAAAAAA" />
                    <Variant mode="AMBIENT" target="alpha" value="0" />
                </TimeText>
            </DigitalClock>
        </Group>

        <!-- Date -->
        <Group x="0" y="300" width="450" height="50">
            <Variant mode="AMBIENT" target="alpha" value="0" />
            <DigitalClock>
                <TimeText format="EEE, MMM d" align="CENTER" x="225" y="25">
                    <Font family="SYNC_TO_DEVICE" size="30" color="[CONFIGURATION.themeColor.0]" />
                </DigitalClock>
            </Group>
    </Scene>
</WatchFace>
